// ==================== ဘာသာပြန် ====================
const translations = {
    my:{title:"🚨 အရေးပေါ်ခေါ်ဆိုရန်",subtitle:"နိုင်ငံရွေးချယ်ပြီး ဖုန်းခေါ်ဆိုနိုင်ပါသည်",search:"နိုင်ငံအမည်ရှာရန်...",noResult:"နိုင်ငံမတွေ့ပါ",police:"ရဲ",ambulance:"လူနာတင်",fire:"မီးသတ်",general:"အထွေထွေ"},
    en:{title:"🚨 Emergency Calls",subtitle:"Select country and call directly",search:"Search country...",noResult:"No countries found",police:"Police",ambulance:"Ambulance",fire:"Fire",general:"General"}
};
let lang="my";
function setLang(l){lang=l;let t=translations[l];
document.getElementById("title").textContent=t.title;
document.getElementById("subtitle").textContent=t.subtitle;
document.getElementById("searchInput").placeholder="🔍 "+t.search;
document.querySelectorAll(".lang-select button").forEach(b=>b.classList.remove("active"));
document.querySelector(`.lang-select button[data-lang="${l}"]`).classList.add("active");
renderList();}

function renderList(){
let s=document.getElementById("searchInput").value.toLowerCase();
let t=translations[lang];
let f=emergencyData.filter(c=>c.en.toLowerCase().includes(s)||c.mm.toLowerCase().includes(s));
let c=document.getElementById("countryList");
if(!f.length){c.innerHTML=`<p class="no-results">${t.noResult}</p>`;return;}
c.innerHTML=f.map(x=>{
let name=lang==="my"?x.mm:x.en;
let btns="";
if(x.police)btns+=`<a href="tel:${x.police}" class="call-btn">👮 ${t.police}: ${x.police}</a>`;
if(x.ambulance)btns+=`<a href="tel:${x.ambulance}" class="call-btn">🚑 ${t.ambulance}: ${x.ambulance}</a>`;
if(x.fire)btns+=`<a href="tel:${x.fire}" class="call-btn">🚒 ${t.fire}: ${x.fire}</a>`;
if(x.general)btns+=`<a href="tel:${x.general}" class="call-btn">🆘 ${t.general}: ${x.general}</a>`;
return `<div class="country-card"><div class="country-header"><span class="country-name">${name}</span><span class="country-capital">📍 ${x.capital}</span></div><div class="number-list">${btns}</div></div>`;}).join("");}
setLang("my");
</script>
</body>
</html>
